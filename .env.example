# DUAT Arena environment template. Copy to .env and fill in values.
# NEVER commit a real key. .env is gitignored; .env.example is not.

# --- Runtime mode ---
# development (default) — local dev; BYOA secrets use a dev key file under logs/
# production          — required for public deploy; see Production checklist below
ENVIRONMENT=development

# Anthropic API key for the LLM trading agent (leave blank to run cache/replay only).
ANTHROPIC_API_KEY=

# Optional: override the LLM model. Defaults to Claude Haiku 4.5 (pinned snapshot).
DUAT_LLM_MODEL=claude-haiku-4-5-20251001

# Optional: LLM agent mode.
#   auto   = use cache if present, otherwise call the API once and record (default)
#   replay = never call the API; use cache only (for demos / no credits)
DUAT_LLM_MODE=auto

# Optional: where the deterministic LLM response cache is stored.
DUAT_LLM_CACHE=logs/llm_cache.json

# --- BYOA (Connect Your Agent) ---
# Required when ENVIRONMENT=production — encrypts stored agent API keys/tokens at rest.
DUAT_BYOA_KEY=

# Required when ENVIRONMENT=production — protects BYOA management routes.
# Clients must send header: X-DUAT-Api-Key
# For private/trusted UI only; set NEXT_PUBLIC_DUAT_ARENA_API_KEY to the same value.
DUAT_ARENA_API_KEY=
NEXT_PUBLIC_DUAT_ARENA_API_KEY=

# Optional: rate limit for POST /api/agents/remote/test (default 20 per 60s per client IP).
DUAT_BYOA_TEST_RATE_LIMIT=20
DUAT_BYOA_TEST_RATE_WINDOW_SECONDS=60

# --- Production checklist (public deploy) ---
# 1. ENVIRONMENT=production
# 2. DUAT_BYOA_KEY=<long random secret>
# 3. DUAT_ARENA_API_KEY=<long random secret> (+ NEXT_PUBLIC_DUAT_ARENA_API_KEY for UI)
# 4. Agent endpoints must be public HTTPS URLs — localhost/127.0.0.1/private IPs are
#    rejected by SSRF protection. Use a tunnel (ngrok, Cloudflare Tunnel, etc.) to test
#    agents running on your machine.
